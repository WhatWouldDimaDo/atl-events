  "scraping_patterns": [
    {
      "script": "consolidate_scrape.py",
      "pattern": "Reads JSON files from results/ folder, maps keys (start_date\u2192Start Date, event_name\u2192Event_Name, etc.), normalizes dates, deduplicates on Event_Name+Venue+Start Date",
      "notes": "Skips non-event files (distillation_queue, distilled_batch, yt_top_artists)"
    },
    {
      "script": "fetch_assets.py",
      "pattern": "Downloads images from venue branding JSON (logo_url) and event JSON (image_url), stores in assets/venues/ and assets/events/, cleans filenames, handles jpg/png/svg extensions",
      "notes": "Uses requests library with User-Agent header, 0.5s throttle between downloads"
    },
    {
      "script": "final_audit.py",
      "pattern": "Audits Master CSV for generic descriptions (slop keywords: \"live at\", \"presents\", \"show at\"), counts enriched descriptions starting with \"Why Dima likes this\", generates interest score distribution",
      "notes": "No active scraping \u2014 quality audit only"
    },
    {
      "script": "taste_matcher.py / taste_matcher_v2.py",
      "pattern": "Matches events to Dima taste profile",
      "notes": "References TASTE_PROFILE.md"
    },
    {
      "script": "analyze_yt_history.py",
      "pattern": "Analyzes YouTube history, extracts artist/event interests",
      "notes": "Outputs to results/yt_top_artists.json"
